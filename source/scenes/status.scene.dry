on-arrival: {!
if (Q.rb_strength) {
    Q.rb_strength_2 = Q.rb_strength.toFixed(1);
}
if (Q.rfb_strength) {
    Q.rfb_strength_2 = Q.rfb_strength.toFixed(1);
}
if (Q.sh_strength) {
    Q.sh_strength_2 = Q.sh_strength.toFixed(1);
}
if (Q.sa_strength) {
    Q.sa_strength_2 = Q.sa_strength.toFixed(1);
}
!}

= Distribution of Power

Heimwehr: [+ sh_force +]%

Schutzbund: [+ rb_force +]%

Police: [+ prussia_force +]%

Bundesheer: [+ army_force +]%

= Paramilitaries

Schutzbund Strength: [+ rb_strength_2 +] thousand

Schutzbund Militarization: [+ rb_militancy : militancy +]

Heimwehr Strength: [+ sh_strength_2 +] thousand

Heimwehr Militarization: [+ sh_militancy : militancy +]

= Official military/paramilitaries

Bundesheer: [+ reichswehr_strength +] thousand troops.

Bundesheer Loyalty: [+ reichswehr_loyalty : loyalty +]

Police: [+ prussian_police_strength +] thousand members.

Police loyalty: [+ prussian_police_loyalty : loyalty +]

@polls
on-arrival: {!
Q.pro_republic_disp = Math.round(Q.pro_republic);
Q.nationalism_disp = Math.round(Q.nationalism);
Q.socialism_disp = Math.round(Q.socialism);
!}

