title: Status
new-page: true
is-special: true
on-arrival: {!
if (Q.unemployed) {
    Q.unemployed_2 = Q.unemployed.toFixed(1);
}
if (Q.inflation) {
    Q.inflation_2 = Q.inflation.toFixed(1);
}
Q.economic_growth_2 = '0';
if (Q.economic_growth) {
    Q.economic_growth_2 = Q.economic_growth.toFixed(1);
}
!}

= Status

[+ month : month +] [+ year +]

Resources available: [+ resources +]

SDAPO position: [? if spd_toleration : toleration ?][? if spd_in_government : in government - ?][? if spd_toleration == 0 and spd_in_government == 0 and spd_caretaker == 0 : opposition ?][? if spd_caretaker : caretaker government ?]
[? if in_grand_coalition and spd_in_government: Grand Coalition ?][? if in_popular_front and spd_in_government: Popular Front ?][? if in_left_front and spd_in_government: Left Front ?][? if in_spd_majority and spd_in_government: SDAPO majority ?][? if in_minority_government and spd_in_government: minority government ?][? if in_emergency_government and spd_in_government: emergency government ?]

[? if spd_in_government and not in_spd_majority and not in_left_front : Coalition dissent: [+ coalition_dissent : coalition_dissent +] ?]

[? if spd_in_government and (in_left_front or in_popular_front): KPO coalition dissent: [+ kpd_coalition_dissent : coalition_dissent +] ?]

Internal dissent: [+ dissent_percent : dissent +]

[? if communist_influence_seen : KPO influence: [+ kpd_influence : kpd_influence +] ?]

= Government

President: [+ president +]

Chancellor: [+ chancellor +] ([+ chancellor_party +])

Nationalrat composition:

# 1928: 30, 1930: 25, 1932: 22
SDAPO: [+ spd_r +]%
# 1928: 15, 1930: 15, 1932: 
CSP: [+ z_r +]%
# 1928: 10, 1930: 13
KPO: [+ kpd_r +]%
# 1928: 14, 1930: 7
GDVP: [+ dnvp_r +]%
# 1928: 9, 1930: 5
LB: [+ dvp_r +]%
# 1928: 5, 1930: 4 (as DstP)
[? if hb_formed == 1 : HB: [+ ddp_r +]% ?]
# 1928: 3, 1930: 18
DNSAP: [+ nsdap_r +]%
# 1928: 9, 1930: 10
Literally anything else: [+ other_r +]%

[? if spd_in_government = 1 : Budget: [+ budget +] ?]

Next election: [+ next_election_month : month +] [+ next_election_year +]

= Economics

Inflation: [+ inflation_2 +]%

[? if black_thursday_seen = 1 : Unemployment: [+ unemployed_2 +]% ?]

Economic growth: [+ economic_growth_2 +]%


# = Public Opinion

@politics

